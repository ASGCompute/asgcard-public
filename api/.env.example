# ASG Card API — Environment Variables
# Copy this file to .env and fill in all REQUIRED values.
# DO NOT commit .env to version control.

# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ── Stellar Configuration ───────────────────────────────
STELLAR_NETWORK=stellar:pubnet
STELLAR_HORIZON_URL=https://horizon.stellar.org
STELLAR_USDC_ASSET=USDC:GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN

# ── REQUIRED: Treasury address (Stellar G... public key) ─
STELLAR_TREASURY_ADDRESS=GAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── REQUIRED: x402 Facilitator (OpenZeppelin) ───────────
# Staging (testnet): https://channels.openzeppelin.com/x402/testnet
# Production: your self-hosted or official mainnet endpoint
FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
FACILITATOR_API_KEY=your-facilitator-api-key
FACILITATOR_TIMEOUT_MS=8000
FACILITATOR_MAX_RETRIES=2

# ── REQUIRED: 4payments Webhook Secret ──────────────────
# Get from: https://business.4payments.io/ → Develop space → Webhooks
WEBHOOK_SECRET=your-webhook-sign-token
# Optional: previous secret for rotation support
# WEBHOOK_SECRET_PREVIOUS=old-webhook-sign-token
