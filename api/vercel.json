{
  "version": 2,
  "builds": [
    {
      "src": "src/vercel.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/vercel.ts"
    }
  ],
  "crons": [
    {
      "path": "/admin/cron/daily-report",
      "schedule": "0 9 * * *"
    }
  ]
}