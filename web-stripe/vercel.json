{
  "rewrites": [
    {
      "source": "/api/stripe-beta/:path*",
      "destination": "https://api.asgcard.dev/stripe-beta/:path*"
    },
    {
      "source": "/approve",
      "destination": "/approve/index.html"
    },
    {
      "source": "/approve/:id/:token",
      "destination": "/approve/index.html"
    }
  ]
}
